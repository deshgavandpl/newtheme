rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - role: string (required, ['admin', 'player', 'scout'])
    //
    // Collection: matches
    // Document ID: matchId
    // Fields:
    //   - teamA: map (required, {name: string})
    //   - teamB: map (required, {name: string})
    //   - scoreA: string (required)
    //   - oversA: string (required)
    //   - status: string (required)
    //   - createdAt: timestamp (required)
    //   - adminId: string (required)
    //
    // Collection: tournaments
    // Document ID: tournamentId
    // Fields:
    //   - name: string (required)
    //   - adminId: string (required)
    //   - status: string (required)
    //
    // Collection: tournaments/{tournamentId}/matches
    // Document ID: matchId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "huseamol123@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.email is string &&
             data.role in ['admin', 'player', 'scout'];
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['teamA', 'teamB', 'status', 'adminId']) &&
             data.teamA is map && data.teamA.name is string &&
             data.teamB is map && data.teamB.name is string &&
             data.status in ['scheduled', 'live', 'finished', 'abandoned'] &&
             data.adminId is string;
    }

    function isValidMatchEvent(data) {
      return data.keys().hasAll(['over', 'ball', 'runs', 'isWicket']) &&
             data.over is int && data.ball is int &&
             data.runs is int && data.isWicket is bool;
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                    (isAdmin() || request.resource.data.role == resource.data.role); // Role immutable for non-admins
    }

    // Match Rules
    match /matches/{matchId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidMatch(request.resource.data) && request.resource.data.adminId == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || resource.data.adminId == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.adminId == request.auth.uid);

      match /events/{eventId} {
        allow read: if true;
        allow create, update: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/matches/$(matchId)).data.adminId == request.auth.uid) && isValidMatchEvent(request.resource.data);
        allow delete: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/matches/$(matchId)).data.adminId == request.auth.uid);
      }
    }

    // Tournament Rules
    match /tournaments/{tournamentId} {
      allow read: if true; // Publicly viewable
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.adminId == request.auth.uid);

      match /matches/{matchId} {
        allow read: if true;
        allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.adminId == request.auth.uid);
      }
    }

    // Player Stats
    match /players/{playerId}/stats {
      allow read: if true;
      allow write: if isAdmin() || isOwner(playerId);
    }
  }
}
